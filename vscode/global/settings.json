{
    "editor.detectIndentation": false,
    "editor.fontFamily": "Liga SFMono Nerd Font, Menlo, monospace",
    "editor.fontWeight": "normal",
    "editor.letterSpacing": -0.3,
    "editor.fontLigatures": true,
    "editor.minimap.enabled": false,
    "editor.fontVariations": false,
    "editor.lineHeight": 1.3,
    "terminal.integrated.fontWeight": "normal",
    "terminal.integrated.fontSize": 15,
    "editor.fontSize": 16,
    "terminal.integrated.letterSpacing": -0.00,
    "terminal.integrated.lineHeight": 1,
    "redhat.telemetry.enabled": false,
    "terminal.integrated.localEchoStyle": "dim",
    "terminal.integrated.fontWeightBold": "normal",
    "files.associations": {
        "**/*.yaml": "ansible",
        "**/*.yml": "ansible",
        "**/*.j2": "jinja",
        "**/*_html.j2": "html",
        "**/*inventory": "ini",
        "**/*hosts": "ini"
    },
    "ansible.executionEnvironment.volumeMounts": [],
    "git.ignoreLegacyWarning": true,
    "workbench.startupEditor": "none",
    "terminal.integrated.enableMultiLinePasteWarning": "never",
 
    "editor.cursorStyle": "block",
    "editor.guides.bracketPairs": true,
    "editor.cursorBlinking": "expand",
    "editor.tokenColorCustomizations": {

    },
    "github.copilot.chat.agent.autoFix": false,
    "github.copilot.chat.agent.runTasks": false,
    "github.copilot.chat.codeGeneration.useInstructionFiles": false,
    "git.enableSmartCommit": true,
    "github.copilot.advanced": {

    
    },
    "remote.SSH.defaultForwardedPorts": [

    ],
    "chat.agent.enabled": false,
    "chat.commandCenter.enabled": false,
    "telemetry.feedback.enabled": false,
    "github.copilot.enable": {
      "*": false
    },
    "ansible.lightspeed.enabled": false,
    "ansible.lightspeed.suggestions.enabled": false,
    "workbench.secondarySideBar.defaultVisibility": "hidden",
    "settingsSync.ignoredExtensions": [],
    "RainbowBrackets.depreciation-notice": false,
    "[dockercompose]": {
      "editor.insertSpaces": true,
      "editor.tabSize": 2,
      "editor.autoIndent": "advanced",
      "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[github-actions-workflow]": {
      "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "terminal.integrated.initialHint": false,
    "terminal.integrated.fontFamily": "Liga SFMono Nerd Font, Menlo, monospace",
    "terminal.integrated.fontLigatures.fallbackLigatures": [

      "<--",
      "<---",
      "<<-",
      "<-",
      "->",
      "->>",
      "-->",
      "--->",
      "<==",
      "<===",
      "<<=",
      "<=",
      "=>",
      "=>>",
      "==>",
      "===>",
      ">=",
      ">>=",
      "<->",
      "<-->",
      "<--->",
      "<---->",
      "<=>",
      "<==>",
      "<===>",
      "<====>",
      "::",
      ":::",
      "<~~",
      "</",
      "</>",
      "/>",
      "~~>",
      "==",
      "!=",
      "/=",
      "~=",
      "<>",
      "===",
      "!==",
      "!===",
      "<:",
      ":=",
      "*=",
      "*+",
      "<*",
      "<*>",
      "*>",
      "<|",
      "<|>",
      "|>",
      "+*",
      "=*",
      "=:",
      ":>",
      "/*",
      "*/",
      "+++",
      "<!--",
      "<!---"
    ],
    "workbench.iconTheme": "catppuccin-mocha",
    "makefile.configureOnOpen": true
}

